BACKEND_API_URL=http://localhost:8001

# Sanity CMS — run `npx sanity login` then `npx sanity init` to get a real
# project ID (see CLAUDE.md's "Sanity CMS" section). Project ID/dataset are
# not secret (Sanity treats them as public), so they're NEXT_PUBLIC_.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
# Shared secret for the Sanity webhook -> /api/revalidate. Optional: content
# still updates within 60s via ISR without this, just not instantly.
SANITY_REVALIDATE_SECRET=

# CoinGecko free "Demo" tier key (starts with "CG-") — get one at
# https://www.coingecko.com/en/developers/dashboard. 10K calls/month, 100
# req/min; the app is designed to use at most one call per 5 minutes
# regardless of traffic (see src/lib/api/coingecko/client.ts). Without this
# set, market data falls back to the static mock roster.
COINGECKO_API_KEY=
