POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

REDIS_URL=

BEAT_TICK_SECONDS=60
DEFAULT_FETCH_INTERVAL_SECONDS=300
INGESTION_THREAD_POOL_SIZE=8

# JSON array of RSS feeds to ingest. Each entry: name (matched against
# news_sources.name to decide insert-vs-update), rss_url, website_url,
# and optional priority/fetch_interval_seconds/is_active (defaults: 0 /
# DEFAULT_FETCH_INTERVAL_SECONDS / true). Edit this list to add, remove,
# or repoint a feed, then run `docker compose up` (or `docker compose run
# --rm seed-sources`) to sync it into the database.
#
# Only Arbitrum, Bitcoin Magazine, and Kraken Blog are active — they're the
# only 3 of the original 8 whose feed reliably includes full article content
# (content:encoded). CoinDesk, Cointelegraph, Ethereum Foundation, Solana,
# and Decrypt only ever provide a short teaser in their feed and are kept
# here with is_active:false as a record of what was evaluated and rejected,
# not deleted — re-activate by flipping is_active back to true/omitting it.
RSS_FEED_SOURCES=[{"name":"CoinDesk","rss_url":"https://www.coindesk.com/arc/outboundfeeds/rss/","website_url":"https://www.coindesk.com","priority":100,"is_active":false},{"name":"Cointelegraph","rss_url":"https://cointelegraph.com/rss","website_url":"https://cointelegraph.com","priority":90,"is_active":false},{"name":"Decrypt","rss_url":"https://decrypt.co/feed","website_url":"https://decrypt.co","priority":80,"is_active":false},{"name":"Bitcoin Magazine","rss_url":"https://bitcoinmagazine.com/feed","website_url":"https://bitcoinmagazine.com","priority":70},{"name":"Ethereum Foundation","rss_url":"https://blog.ethereum.org/feed.xml","website_url":"https://blog.ethereum.org","priority":60,"is_active":false},{"name":"Solana","rss_url":"https://solana.com/news/rss.xml","website_url":"https://solana.com/news","priority":50,"is_active":false},{"name":"Arbitrum (Offchain Labs)","rss_url":"https://blog.arbitrum.io/feed","website_url":"https://blog.arbitrum.io","priority":50},{"name":"Kraken Blog","rss_url":"https://blog.kraken.com/feed","website_url":"https://blog.kraken.com","priority":40}]
FEED_FETCH_MAX_ATTEMPTS=2
FEED_FETCH_RETRY_BACKOFF_SECONDS=1.0

ARTICLE_CACHE_TTL_SECONDS=600
LATEST_LIST_CACHE_TTL_SECONDS=60
LATEST_LIST_DEFAULT_LIMIT=20
HOMEPAGE_CACHE_TTL_SECONDS=60
FEATURED_CACHE_TTL_SECONDS=90
TRENDING_CACHE_TTL_SECONDS=90
CATEGORY_LIST_CACHE_TTL_SECONDS=180

FETCH_LOCK_TTL_SECONDS=25
FEED_FETCH_TIMEOUT_SECONDS=10

LOG_LEVEL=INFO
